# To separate your traces from other application
LANGSMITH_PROJECT=new-agent

# Add API keys for connecting to LLM providers, data sources, and other integrations here

# LangGraph API persistence. Point this to a Postgres database.
# When Postgres is already published on the Docker host at 5432, use the Docker
# bridge gateway from inside containers.
DATABASE_URI=postgresql://postgres:postgres@172.17.0.1:5432/postgres?sslmode=disable

# Optional Redis persistence/queue URI for LangGraph API.
REDIS_URI=redis://172.17.0.1:6380
